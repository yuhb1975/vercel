{
  "routes": [
    {
      "src": "/gone",
      "status": 410,
      "transforms": [
        {
          "type": "response.headers",
          "op": "set",
          "target": { "key": "x-gone-resp" },
          "args": "1"
        }
      ]
    },
    {
      "src": "/old",
      "status": 308,
      "headers": { "Location": "/new" },
      "transforms": [
        {
          "type": "response.headers",
          "op": "set",
          "target": { "key": "x-should-not-apply" },
          "args": "1"
        }
      ]
    },
    {
      "src": "/transform/(.*)",
      "destination": {
        "type": "service",
        "service": "backend"
      },
      "transforms": [
        {
          "type": "response.headers",
          "op": "set",
          "target": { "key": "x-marker-should-not-apply" },
          "args": "1"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/svc/:path*",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/api/:path*"
      }
    },
    {
      "source": "/rw/:path*",
      "destination": {
        "type": "service",
        "service": "backend"
      },
      "transforms": [
        {
          "type": "request.path",
          "op": "set",
          "args": "/api/:path*"
        }
      ]
    },
    {
      "source": "/:path*",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ],
  "experimentalServicesV2": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "framework": "fastapi",
      "entrypoint": "server.py",
      "redirects": [
        {
          "source": "/api/old",
          "destination": "/api/new",
          "permanent": true
        }
      ],
      "headers": [
        {
          "source": "/api/(.*)",
          "headers": [
            {
              "key": "x-backend-service",
              "value": "backend"
            }
          ]
        }
      ],
      "routes": [
        {
          "src": "/api/legacy",
          "status": 308,
          "headers": {
            "Location": "/api/new"
          }
        },
        {
          "src": "/transform/(.*)",
          "transforms": [
            {
              "type": "request.path",
              "op": "set",
              "args": "/api/$1"
            },
            {
              "type": "request.query",
              "op": "set",
              "target": { "key": "injected" },
              "args": "yes"
            },
            {
              "type": "request.headers",
              "op": "set",
              "target": { "key": "x-injected" },
              "args": "hdr"
            },
            {
              "type": "response.headers",
              "op": "set",
              "target": { "key": "x-resp-injected" },
              "args": "resp"
            },
            {
              "type": "response.headers",
              "op": "set",
              "target": { "key": "x-overridden" },
              "args": "overridden"
            }
          ]
        }
      ]
    }
  }
}
